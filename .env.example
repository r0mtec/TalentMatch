# Окружение Laravel-приложений. Для локальной разработки оставьте `local`.
APP_ENV=local

# Включает подробный вывод ошибок Laravel. Выключайте вне локальной разработки.
APP_DEBUG=true

# Публичный URL приложения. Используется backend-сервисами при генерации ссылок.
APP_URL=http://localhost:8080

# Ключ шифрования Laravel. Для нелокальных окружений сгенерируйте реальный ключ.
APP_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Базовый URL API, который использует React frontend.
VITE_API_BASE_URL=http://localhost:8080/api

# Имя базы PostgreSQL для Docker Compose и Laravel.
POSTGRES_DB=talentmatch

# Пользователь PostgreSQL для Docker Compose и Laravel.
POSTGRES_USER=talentmatch

# Пароль PostgreSQL. Меняйте для общих и развернутых окружений.
POSTGRES_PASSWORD=talentmatch

# Порт PostgreSQL на машине разработчика.
DB_PORT=5432

# Порт Redis на машине разработчика.
REDIS_PORT=6379

# Root access key для MinIO. Используется Laravel как S3-compatible access key.
MINIO_ROOT_USER=minio

# Root secret key для MinIO. Меняйте для общих и развернутых окружений.
MINIO_ROOT_PASSWORD=minio-password

# Регион для S3-compatible хранилища. Для MinIO подходит значение по умолчанию.
AWS_DEFAULT_REGION=ru-central1

# Bucket, в котором хранятся загруженные резюме.
AWS_BUCKET=resumes

# Максимальный размер загружаемого резюме в мегабайтах.
MAX_UPLOAD_SIZE_MB=15
