# Environment files
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS and editor files
.DS_Store
Thumbs.db
.idea/
.vscode/

# Dependencies
node_modules/
vendor/
backend/services/*/vendor/

# Frontend build artifacts
dist/
dist-ssr/
.vite/
frontend/dist/
frontend/.vite/
*.tsbuildinfo
coverage/

# Laravel runtime files
**/storage/*.key
**/storage/app/*
!**/storage/app/.gitignore
**/storage/framework/*
!**/storage/framework/.gitignore
**/storage/logs/*
!**/storage/logs/.gitignore
bootstrap/cache/*.php
backend/services/*/bootstrap/cache/*.php

# Logs and caches
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.cache/
.phpunit.result.cache

# Docker/local overrides
docker-compose.override.yml
